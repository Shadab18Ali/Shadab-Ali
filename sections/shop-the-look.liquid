{{ 'shop-the-look.css' | asset_url | stylesheet_tag }}

<div class="stl-section" id="stl-{{ section.id }}">
  {% if section.settings.heading != blank %}
    <h2 class="stl-heading">{{ section.settings.heading }}</h2>
  {% endif %}

  <div class="stl-grid">
    {% for block in section.blocks %}
      {% if block.type == 'look_product' %}
        {% assign product = block.settings.product %}
        <div class="stl-cell" {{ block.shopify_attributes }}>
          {% if product != blank %}
            <img
              src="{{ product.featured_image | image_url: width: 800 }}"
              alt="{{ product.featured_image.alt | default: product.title | escape }}"
              loading="lazy"
              class="stl-img"
            >
            <button
              type="button"
              class="stl-hotspot"
              style="left: {{ block.settings.hotspot_x }}%; top: {{ block.settings.hotspot_y }}%;"
              data-stl-product-handle="{{ product.handle }}"
              aria-label="Shop {{ product.title | escape }}"
            >+</button>
          {% else %}
            <div class="stl-img stl-img--placeholder"></div>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

<!-- Popup markup (single reusable modal) -->
<div class="stl-modal" id="stl-modal-{{ section.id }}" hidden>
  <div class="stl-modal__overlay" data-stl-close></div>
  <div class="stl-modal__panel" role="dialog" aria-modal="true">
    <button type="button" class="stl-modal__close" data-stl-close aria-label="Close">&times;</button>

    <div class="stl-modal__top">
      <div class="stl-modal__media">
        <img class="stl-modal__image" src="" alt="">
      </div>
      <div class="stl-modal__info">
        <h3 class="stl-modal__title"></h3>
        <p class="stl-modal__price"></p>
        <div class="stl-modal__description"></div>
      </div>
    </div>

    <form class="stl-modal__form">
      <div class="stl-modal__options"></div>
      <p class="stl-modal__stock-msg" hidden>This combination is unavailable.</p>
      <button type="submit" class="stl-modal__add-btn">
        <span class="stl-btn-text">ADD TO CART</span>
        <span class="stl-btn-arrow">&rarr;</span>
      </button>
      <p class="stl-modal__added-msg" hidden>Added to cart.</p>
    </form>
  </div>
</div>

<script>
  window.stlSectionSettings = window.stlSectionSettings || {};
  window.stlSectionSettings["{{ section.id }}"] = {
    bundleEnabled: {{ section.settings.enable_bundle | json }},
    bundleOption1: {{ section.settings.bundle_option_1 | json }},
    bundleOption2: {{ section.settings.bundle_option_2 | json }},
    bundleProductHandle: {{ section.settings.bundle_product.handle | json }}
  };
</script>
<script src="{{ 'shop-the-look.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Shop the Look Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop the look"
    },
    {
      "type": "header",
      "content": "Auto-bundle rule"
    },
    {
      "type": "paragraph",
      "content": "If the customer's selected variant matches BOTH option values below, the chosen bundle product is auto-added to cart alongside the main item."
    },
    {
      "type": "checkbox",
      "id": "enable_bundle",
      "label": "Enable auto-bundle",
      "default": true
    },
    {
      "type": "text",
      "id": "bundle_option_1",
      "label": "Trigger option value 1",
      "default": "Black"
    },
    {
      "type": "text",
      "id": "bundle_option_2",
      "label": "Trigger option value 2",
      "default": "Medium"
    },
    {
      "type": "product",
      "id": "bundle_product",
      "label": "Product to auto-add (e.g. Soft Winter Jacket)"
    }
  ],
  "blocks": [
    {
      "type": "look_product",
      "name": "Look product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product",
          "info": "Image shown is pulled automatically from this product's featured image."
        },
        {
          "type": "range",
          "id": "hotspot_x",
          "label": "Hotspot horizontal position",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 80
        },
        {
          "type": "range",
          "id": "hotspot_y",
          "label": "Hotspot vertical position",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 20
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop the Look Grid",
      "blocks": [
        { "type": "look_product" },
        { "type": "look_product" },
        { "type": "look_product" },
        { "type": "look_product" },
        { "type": "look_product" },
        { "type": "look_product" }
      ]
    }
  ]
}
{% endschema %}
