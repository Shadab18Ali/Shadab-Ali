<div class="tisso-banner" style="background-image: url('{{ section.settings.background_image | image_url: width: 1800 }}');">

  <div class="tisso-banner__top">
    <div class="tisso-banner__top-text">{{ section.settings.top_text }}</div>

    {% if section.settings.top_button_text != blank %}
      <a href="{{ section.settings.top_button_link }}" class="tisso-btn tisso-btn--yellow">
        <span>{{ section.settings.top_button_text }}</span>
        <span class="tisso-btn__arrow">&rarr;</span>
      </a>
    {% endif %}
  </div>

  <div class="tisso-banner__content">
    <h1 class="tisso-banner__heading">{{ section.settings.heading }}</h1>
    <p class="tisso-banner__description">{{ section.settings.description }}</p>

    {% if section.settings.shop_now_text != blank %}
      <a href="{{ section.settings.shop_now_link }}" class="tisso-btn tisso-btn--dark">
        <span>{{ section.settings.shop_now_text }}</span>
        <span class="tisso-btn__arrow">&rarr;</span>
      </a>
    {% endif %}
  </div>

  {% comment %} Mobile-only illustration, hidden on desktop via CSS {% endcomment %}
  {% if section.settings.background_image != blank %}
    <img
      class="tisso-banner__mobile-image"
      src="{{ section.settings.background_image | image_url: width: 800 }}"
      alt=""
      loading="lazy"
    >
  {% endif %}

  {% if section.settings.bottom_text != blank %}
    <div class="tisso-banner__bottom-bar">{{ section.settings.bottom_text }}</div>
  {% endif %}

</div>

{{ 'banner.css' | asset_url | stylesheet_tag }}

{% schema %}
{
  "name": "Custom Banner",
  "settings": [
    { "type": "image_picker", "id": "background_image", "label": "Background image" },
    { "type": "text", "id": "top_text", "label": "Top announcement text", "default": "Find the ideal gift for your loved ones." },
    { "type": "text", "id": "top_button_text", "label": "Top button text", "default": "CHOOSE GIFT" },
    { "type": "url", "id": "top_button_link", "label": "Top button link" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Gift Guide" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season." },
    { "type": "text", "id": "shop_now_text", "label": "Shop now button text", "default": "SHOP NOW" },
    { "type": "url", "id": "shop_now_link", "label": "Shop now button link" },
    { "type": "text", "id": "bottom_text", "label": "Bottom bar text", "default": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL" }
  ],
  "presets": [
    { "name": "Custom Banner" }
  ]
}
{% endschema %}