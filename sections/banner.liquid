

{{ 'section-banner.css' | asset_url | stylesheet_tag }}

<div class="gift-banner" id="Banner-{{ section.id }}" style="--banner-bg: {{ section.settings.bg_color }};">

  {% comment %} ===== Desktop topbar (hidden on mobile) ===== {% endcomment %}
  {% if section.settings.logo_text != blank or section.settings.top_bar_text != blank or section.settings.choose_gift_text != blank %}
    <div class="gift-banner__topbar gift-banner__topbar--desktop">
      {% if section.settings.logo_text != blank %}
        <p class="gift-banner__logo">{{ section.settings.logo_text }}</p>
      {% endif %}

      {% if section.settings.top_bar_text != blank %}
        <p class="gift-banner__topbar-text">{{ section.settings.top_bar_text }}</p>
      {% endif %}

      {% if section.settings.choose_gift_text != blank %}
        <a
          href="{{ section.settings.choose_gift_link | default: '#' }}"
          class="gift-banner__btn gift-banner__btn--outline animated-btn"
        >
          <span>{{ section.settings.choose_gift_text }}</span>
          <span class="animated-btn__arrow" aria-hidden="true">→</span>
        </a>
      {% endif %}
    </div>
  {% endif %}

 
  <div class="gift-banner__mobile-header">
    <span class="gift-banner__menu-icon" aria-hidden="true">
      <span></span><span></span><span></span>
    </span>
    {% if section.settings.logo_text != blank %}
      <p class="gift-banner__logo gift-banner__logo--mobile">{{ section.settings.logo_text }}</p>
    {% endif %}
  </div>

  {% assign desktop_bg_opacity = section.settings.text_block_bg_opacity_desktop | divided_by: 100.0 %}
  {% assign mobile_bg_opacity = section.settings.text_block_bg_opacity_mobile | divided_by: 100.0 %}

  <div
    class="gift-banner__main gift-banner__main--desktop"
    style="justify-content: {% case section.settings.text_alignment_desktop %}{% when 'center' %}center{% when 'right' %}flex-end{% else %}flex-start{% endcase %};"
  >
    {% if section.settings.banner_image != blank %}
      <div class="gift-banner__image">
        <img
          src="{{ section.settings.banner_image | image_url: width: 2000 }}"
          alt="{{ section.settings.banner_image.alt | default: section.settings.heading | escape }}"
          loading="lazy"
          width="{{ section.settings.banner_image.width }}"
          height="{{ section.settings.banner_image.height }}"
        >
      </div>
    {% endif %}

    <div
      class="gift-banner__text"
      style="
        --heading-size: {{ section.settings.heading_font_size_desktop | default: 72 }}px;
        --desc-size: {{ section.settings.description_font_size_desktop | default: 24 }}px;
        --text-bg: {{ section.settings.text_block_bg_color_desktop | color_modify: 'alpha', desktop_bg_opacity }};
        text-align: {{ section.settings.text_alignment_desktop | default: 'left' }};
      "
    >
      {% if section.settings.heading != blank %}
        <h1 class="gift-banner__heading">{{ section.settings.heading }}</h1>
      {% endif %}

      {% if section.settings.description != blank %}
        <div class="gift-banner__description">{{ section.settings.description }}</div>
      {% endif %}

      {% if section.settings.shop_now_text != blank %}
        <a
          href="{{ section.settings.shop_now_link | default: '#' }}"
          class="gift-banner__btn gift-banner__btn--solid animated-btn"
        >
          <span>{{ section.settings.shop_now_text }}</span>
          <span class="animated-btn__arrow" aria-hidden="true">→</span>
        </a>
      {% endif %}
    </div>
  </div>

 
  <div class="gift-banner__main--mobile">
    <div
      class="gift-banner__text--mobile"
      style="
        --heading-size: {{ section.settings.heading_font_size_mobile | default: 32 }}px;
        --desc-size: {{ section.settings.description_font_size_mobile | default: 14 }}px;
        --text-bg: {{ section.settings.text_block_bg_color_mobile | color_modify: 'alpha', mobile_bg_opacity }};
        text-align: {{ section.settings.text_alignment_mobile | default: 'left' }};
      "
    >
      {% if section.settings.heading != blank %}
        <h1 class="gift-banner__heading">{{ section.settings.heading }}</h1>
      {% endif %}

      {% if section.settings.description != blank %}
        <div class="gift-banner__description">{{ section.settings.description }}</div>
      {% endif %}
    </div>

    {% assign mobile_img = section.settings.mobile_banner_image | default: section.settings.banner_image %}
    {% if mobile_img != blank %}
      <div class="gift-banner__mobile-image-wrap">
        <img
          src="{{ mobile_img | image_url: width: 1000 }}"
          alt="{{ mobile_img.alt | default: section.settings.heading | escape }}"
          loading="lazy"
          width="{{ mobile_img.width }}"
          height="{{ mobile_img.height }}"
        >
        {% if section.settings.shop_now_text != blank %}
          <a
            href="{{ section.settings.shop_now_link | default: '#' }}"
            class="gift-banner__btn gift-banner__btn--solid gift-banner__btn--mobile-overlay animated-btn"
            style="
              {% case section.settings.shop_now_position_mobile %}
                {% when 'center' %}
                  left: 0; right: 0; margin-left: auto; margin-right: auto; width: max-content;
                {% when 'right' %}
                  left: auto; right: 1.5rem;
                {% else %}
                  left: 1.5rem; right: auto;
              {% endcase %}
            "
          >
            <span>{{ section.settings.shop_now_text }}</span>
            <span class="animated-btn__arrow" aria-hidden="true">→</span>
          </a>
        {% endif %}
      </div>
    {% endif %}
  </div>

  {% comment %} Bottom info bar {% endcomment %}
  {% if section.settings.bottom_bar_text != blank %}
    <div class="gift-banner__bottombar">
      <p>{{ section.settings.bottom_bar_text }}</p>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Banner",
  "tag": "section",
  "class": "section-banner",
  "settings": [
    {
      "type": "header",
      "content": "Top bar"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo / brand text",
      "default": "TISSO VISON"
    },
    {
      "type": "text",
      "id": "top_bar_text",
      "label": "Top announcement text",
      "default": "Find the ideal gift for your loved ones."
    },
    {
      "type": "text",
      "id": "choose_gift_text",
      "label": "\"Choose gift\" button label",
      "default": "CHOOSE GIFT"
    },
    {
      "type": "url",
      "id": "choose_gift_link",
      "label": "\"Choose gift\" button link"
    },
    {
      "type": "header",
      "content": "Main content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season.</p>"
    },
    {
      "type": "text",
      "id": "shop_now_text",
      "label": "\"Shop now\" button label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "shop_now_link",
      "label": "\"Shop now\" button link"
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner illustration (desktop)"
    },
    {
      "type": "image_picker",
      "id": "mobile_banner_image",
      "label": "Banner illustration (mobile)",
      "info": "If left blank, the desktop image is used instead."
    },
    {
      "type": "select",
      "id": "shop_now_position_mobile",
      "label": "\"Shop now\" button position (mobile image overlay)",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Desktop text style"
    },
    {
      "type": "select",
      "id": "text_alignment_desktop",
      "label": "Text alignment (desktop)",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "heading_font_size_desktop",
      "label": "Heading font size (desktop)",
      "min": 24,
      "max": 96,
      "step": 2,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "description_font_size_desktop",
      "label": "Description font size (desktop)",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "color",
      "id": "text_block_bg_color_desktop",
      "label": "Text block background color",
      "default": "#f7f6f3"
    },
    {
      "type": "range",
      "id": "text_block_bg_opacity_desktop",
      "label": "Text block background opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 92
    },
    {
      "type": "header",
      "content": "Mobile text style"
    },
    {
      "type": "select",
      "id": "text_alignment_mobile",
      "label": "Text alignment (mobile)",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "heading_font_size_mobile",
      "label": "Heading font size (mobile)",
      "min": 18,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "description_font_size_mobile",
      "label": "Description font size (mobile)",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "text_block_bg_color_mobile",
      "label": "Text block background color",
      "default": "#f7f6f3"
    },
    {
      "type": "range",
      "id": "text_block_bg_opacity_mobile",
      "label": "Text block background opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Bottom bar"
    },
    {
      "type": "text",
      "id": "bottom_bar_text",
      "label": "Bottom bar text",
      "default": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#f7f6f3"
    }
  ],
  "presets": [
    {
      "name": "Banner"
    }
  ]
}
{% endschema %}
